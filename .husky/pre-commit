#!/bin/sh

set -e

echo "Checking Queens DB-backed export fingerprint..."
yarn db:sync-exported-artifacts

yarn lint:fix
yarn --cwd frontend build

if git diff --cached --name-only --diff-filter=ACMR | grep -Eq '^(frontend/|queens-admin-backend/|package\.json|frontend/package\.json|\.gitlab-ci\.yml|\.husky/pre-commit)'; then
  echo "Staged app or backend changes detected. Running smoke tests..."
  yarn test:smoke
fi
