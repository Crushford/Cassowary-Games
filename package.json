{
  "name": "honey-pot-ants",
  "private": true,
  "packageManager": "yarn@4.10.3",
  "scripts": {
    "prepare": "husky",
    "dev": "sh -c 'yarn dev:db && trap \"kill 0\" EXIT; yarn dev:frontend & yarn dev:kotlin-backend & wait'",
    "dev:db": "docker compose up -d queens-admin-postgres",
    "dev:db:stop": "docker compose stop queens-admin-postgres",
    "test": "sh -c 'yarn test:ts && yarn test:kotlin'",
    "test:ts": "yarn --cwd frontend test",
    "test:kotlin": "sh -c 'cd queens-admin-backend && GRADLE_USER_HOME=\"$PWD/.gradle-local\" gradle test'",
    "test:kotlin:tests": "sh -c 'cd queens-admin-backend && GRADLE_USER_HOME=\"$PWD/.gradle-local\" gradle test \"$@\"' --",
    "db:import-legacy-puzzles": "sh -c 'cd queens-admin-backend && GRADLE_USER_HOME=\"$PWD/.gradle-local\" gradle importLegacyPuzzles'",
    "db:export-puzzles-json": "sh -c 'cd queens-admin-backend && GRADLE_USER_HOME=\"$PWD/.gradle-local\" gradle exportPuzzlesJson'",
    "db:assess-puzzle-difficulties": "sh -c 'cd queens-admin-backend && GRADLE_USER_HOME=\"$PWD/.gradle-local\" gradle assessPuzzleDifficulties'",
    "db:assess-puzzle-difficulties:overwrite": "sh -c 'cd queens-admin-backend && GRADLE_USER_HOME=\"$PWD/.gradle-local\" gradle assessPuzzleDifficultiesOverwrite'",
    "dev:frontend": "yarn --cwd frontend dev",
    "dev:kotlin-backend": "sh -c 'cd queens-admin-backend && GRADLE_USER_HOME=\"$PWD/.gradle-local\" gradle bootRun'",
    "lint": "sh -c 'yarn lint:frontend; f=$?; yarn lint:backend; b=$?; test $f -eq 0 -a $b -eq 0'",
    "lint:frontend": "yarn --cwd frontend lint",
    "lint:backend": "yarn --cwd backend lint",
    "lint:fix": "lint-staged",
    "format": "yarn format:frontend && yarn format:backend",
    "format:frontend": "yarn --cwd frontend format",
    "format:backend": "yarn --cwd backend format"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6"
  },
  "lint-staged": {
    "frontend/src/**/*.{js,ts,vue}": [
      "yarn --cwd frontend eslint --ext .js,.ts,.vue --ignore-path .gitignore --fix",
      "yarn --cwd frontend prettier --write",
      "yarn --cwd frontend lint:theme-colors"
    ],
    "backend/**/*.ts": [
      "yarn --cwd backend prettier --write"
    ]
  }
}
