# Point-and-click scene pipeline
# Use mock mode for local development to avoid external API calls.
POINTANDCLICK_IMAGE_GENERATION_MODE=mock

# Set to openai to enable real image generation from backend only.
# POINTANDCLICK_IMAGE_GENERATION_MODE=openai

# Required only when POINTANDCLICK_IMAGE_GENERATION_MODE=openai
OPENAI_API_KEY=

# Optional override for scene markdown location.
# Default: ../vendor/cassowary-world-lore
CASSOWARY_LORE_PATH=../vendor/cassowary-world-lore

# Optional image model override
POINTANDCLICK_OPENAI_IMAGE_MODEL=gpt-image-1
