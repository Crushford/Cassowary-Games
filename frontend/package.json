{
  "name": "cassowary-games",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:story:smoke": "vitest run src/games/queens/stores/queensStoryMode.smoke.spec.ts",
    "test:story:full": "vitest run src/games/queens/stores/queensStoryMode.full.spec.ts",
    "lint": "eslint --ext .js,.ts,.vue --ignore-path .gitignore src && yarn lint:theme-colors",
    "lint:fix": "eslint --ext .js,.ts,.vue --ignore-path .gitignore --fix src",
    "lint:theme-colors": "node scripts/lint-theme-colors.mjs",
    "format": "prettier --write \"src/**/*.{ts,vue}\"",
    "generate": "cd cli-tools && yarn generate",
    "puzzle-db": "cd cli-tools && yarn puzzle-db",
    "server": "cd cli-tools && yarn server",
    "dev:server": "cd cli-tools && yarn dev:server",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "rm -rf dist/storybook-static storybook-static && STORYBOOK_SKIP_STATIC=1 storybook build && cp -rp public/. storybook-static/",
    "build:all": "yarn build && yarn build-storybook",
    "chromatic": "npx chromatic --project-token=chpt_21e63b4cf6a8756",
    "print:odds": "tsx scripts/printOddsTables.ts"
  },
  "dependencies": {
    "@primevue/themes": "^4.5.4",
    "@vueuse/core": "^14.2.1",
    "motion-v": "^2.2.0",
    "pinia": "^3.0.3",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.4",
    "vue": "^3.5.13",
    "vue-gtag": "^3.7.0",
    "vue-router": "4"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.1",
    "@pinia/testing": "^1.0.2",
    "@storybook/addon-a11y": "^9.1.2",
    "@storybook/addon-docs": "^9.1.2",
    "@storybook/addon-links": "^9.1.2",
    "@storybook/addon-onboarding": "^9.1.2",
    "@storybook/addon-vitest": "^9.1.2",
    "@storybook/vue3": "^9.1.2",
    "@storybook/vue3-vite": "^9.1.2",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "@types/node": "^24.1.0",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/tsconfig": "^0.7.0",
    "autoprefixer": "^10.4.17",
    "chromatic": "^13.2.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-storybook": "^9.1.2",
    "eslint-plugin-vue": "^10.0.0",
    "playwright": "^1.55.0",
    "postcss": "^8.4.35",
    "prettier": "^3.5.3",
    "storybook": "^9.1.2",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.20.6",
    "typescript": "~5.7.2",
    "vite": "^6.2.0",
    "vite-plugin-eslint": "^1.8.1",
    "vitest": "^3.2.4",
    "vue-eslint-parser": "^10.1.3",
    "vue-tsc": "^2.2.4"
  },
  "browserslist": [
    "defaults",
    "not IE 11",
    "maintained node versions"
  ],
  "packageManager": "yarn@4.9.1"
}
